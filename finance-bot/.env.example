# FinClaw .env.example
# Copy to .env and fill in your values. Never commit .env to git.

# --- Discord Bot (required for Discord channel) ---
# Create a bot at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# --- Gateway Auth (required) ---
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# --- Ollama (local LLM) ---
OLLAMA_HOST=http://localhost:11434

# --- Finance: Watchlist ---
# Comma-separated tickers to monitor
FINANCE_MONITOR_WATCHLIST=AAPL,MSFT,NVDA,BTC-USD,ETH-USD

# --- moomoo (paper/live trading API) ---
# Available in Canada (CIRO-regulated). Sign up at moomoo.com
# Get OpenAPI access at: https://www.moomoo.com/OpenAPI
# Download and run OpenD gateway on the host machine
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111
MOOMOO_TRADE_ENV=SIMULATE   # SIMULATE for paper trading, REAL for live
MOOMOO_SECURITY_FIRM=FUTUINC
# MOOMOO_TRADE_PWD=          # your trading unlock password (set when ready)

# ─── Search & Research (Tavily is REQUIRED for news/research) ─────────────

# Tavily Search — REQUIRED — the primary news/research engine for FinClaw
# Without this, the bot cannot search for breaking news, earnings details, or analyst reports
# Get free key at: https://app.tavily.com
TAVILY_API_KEY=

# Brave Search (brave-search skill) — fallback search, 2,000 free queries/month
# Get key at: https://api.search.brave.com
BRAVE_SEARCH_API_KEY=

# ─── Productivity Skills ─────────────────────────────────────────────────────

# Notion (notion skill) — trade journal, research notes
# Get key at: https://developers.notion.com → Create integration
NOTION_API_KEY=

# Trello (trello skill) — optional, for tracking strategies/positions
# Get key at: https://trello.com/app-key
TRELLO_API_KEY=
TRELLO_TOKEN=

# ─── Social Media / Sentiment ───────────────────────────────────────────────

# Twitter/X (x-research + xurl skills) — market sentiment, trending tickers
# Get key at: https://developer.twitter.com
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=

# Reddit (market-sentiment skill — PRAW) — WSB/investing sentiment
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
WATCHTOWER_SLACK_WEBHOOK_URL=
REDDIT_USER_AGENT=finclaw/1.0

# ─── Optional: Cloud AI Fallback ────────────────────────────────────────────
# Used only if local Ollama is unavailable. Leave blank for fully local setup.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
